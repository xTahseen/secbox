API_ID=12345678
API_HASH=0123456789abcdef0123456789abcdef
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi

MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
DATABASE_NAME=my_database

WEBUI_HOST=0.0.0.0
WEBUI_PORT=8080

WEBUI_SECRET_KEY=your-random-secret-key-here
WEBUI_BASE_URL=https://files.example.com

# Comma-separated Telegram user IDs allowed to use admin-only commands (/stats)
ADMIN_IDS=123456789,987654321

# Telegram group/channel ID where new-user-joined notifications are sent.
# Bot must be a member of this group. Leave unset to disable notifications.
LOG_GROUP_ID=-1001234567890
